---
import Base from '../../layouts/Base.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const pinned = all.filter((n) => n.data.pinned);
const unpinned = all.filter((n) => !n.data.pinned);

const categories = [
  { id: 'leads-sales', label: 'Leads & Sales' },
  { id: 'data-reporting', label: 'Data & Reporting' },
  { id: 'retention', label: 'Retention' },
  { id: 'team', label: 'Team' },
];
---

<Base title="Notes from the Floor · Rack & Roster">
  <section class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">Notes from the Floor</h1>
    <p class="mt-3 italic text-neutral-600">Writing from Stephen Hines on running traditional strength gyms.</p>

    <div class="mt-8 flex flex-wrap gap-x-4 gap-y-2 font-sans text-sm" data-filter-bar>
      <button
        type="button"
        data-filter="all"
        class="filter-pill underline underline-offset-4 text-[color:var(--color-ink)]"
        aria-pressed="true"
      >All</button>
      {categories.map((cat) => (
        <button
          type="button"
          data-filter={cat.id}
          class="filter-pill text-neutral-500 hover:text-neutral-800"
          aria-pressed="false"
        >{cat.label}</button>
      ))}
    </div>

    {pinned.length > 0 && (
      <div class="mt-10" data-section="pinned">
        <p class="italic text-sm text-neutral-500">Start here</p>
        <div class="mt-3">
          {pinned.map((note) => (
            <div data-note-tags={(note.data.tags ?? []).join(' ')}>
              <NoteCard
                title={note.data.title}
                summary={note.data.summary}
                date={note.data.date}
                slug={note.id}
              />
            </div>
          ))}
        </div>
      </div>
    )}

    {unpinned.length > 0 && (
      <div class={pinned.length > 0 ? 'mt-10' : 'mt-8'} data-section="unpinned">
        {unpinned.map((note) => (
          <div data-note-tags={(note.data.tags ?? []).join(' ')}>
            <NoteCard
              title={note.data.title}
              summary={note.data.summary}
              date={note.data.date}
              slug={note.id}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</Base>

<script>
  const bar = document.querySelector('[data-filter-bar]');
  if (bar) {
    const pills = bar.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('[data-note-tags]');

    const setActive = (active: HTMLButtonElement) => {
      pills.forEach((p) => {
        const isActive = p === active;
        p.setAttribute('aria-pressed', String(isActive));
        p.classList.toggle('underline', isActive);
        p.classList.toggle('text-[color:var(--color-ink)]', isActive);
        p.classList.toggle('text-neutral-500', !isActive);
        p.classList.toggle('hover:text-neutral-800', !isActive);
      });
    };

    const applyFilter = (filter: string) => {
      cards.forEach((card) => {
        const tags = (card.dataset.noteTags ?? '').split(/\s+/).filter(Boolean);
        const match = filter === 'all' || tags.includes(filter);
        card.style.display = match ? '' : 'none';
      });
    };

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter ?? 'all';
        setActive(pill);
        applyFilter(filter);
      });
    });
  }
</script>
