---
import Base from './Base.astro';

interface Props {
  title: string;
  heading: string;
  description?: string;
  pullQuote?: string;
}

const { title, heading, description, pullQuote } = Astro.props;
---

<Base title={title} description={description}>
  <article class="mx-auto max-w-[72ch] px-6 py-12 sm:py-16">
    <div class="note-body">
      <h1>{heading}</h1>
      {pullQuote && (
        <aside class="pull-quote">
          <p>{pullQuote}</p>
        </aside>
      )}
      <slot />
    </div>
  </article>
</Base>
