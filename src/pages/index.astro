---
import Base from '../layouts/Base.astro';
import NoteCard from '../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const pinned = all.filter((n) => n.data.pinned);
const unpinned = all.filter((n) => !n.data.pinned);
const recent = [...pinned, ...unpinned.slice(0, 3)];
---

<Base title="Rack & Roster">
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-10 sm:pt-24">
    <h1 class="text-5xl sm:text-6xl leading-[1.05] font-semibold tracking-tight">
      Notes from the floor.
    </h1>
    <p class="mt-6 text-xl leading-relaxed text-neutral-800">
      Field notes from a decade inside Manhattan strength gyms.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-11 border-t border-neutral-200/70">
    <div>
      {recent.map((note) => (
        <NoteCard
          title={note.data.title}
          summary={note.data.summary}
          date={note.data.date}
          slug={note.id}
        />
      ))}
    </div>
    <p class="mt-6">
      <a href="/notes" class="underline underline-offset-4 hover:text-neutral-600">See all notes &rarr;</a>
    </p>
  </section>
</Base>
